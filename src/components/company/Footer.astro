        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h4 class="text-base font-semibold uppercase tracking-wider">
          Company
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >About Us</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Our Team</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Careers</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div class="space-y-4">
        <h4 class="text-base font-semibold uppercase tracking-wider">
          Services
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >SEO Optimization</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Content Marketing</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Social Media</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Analytics</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-4">
        <h4 class="text-base font-semibold uppercase tracking-wider">
          Contact
        </h4>
        <ul class="space-y-2">
          <li class="flex items-center gap-2 text-base-content/70">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
